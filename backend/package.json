{
  "name": "shipyard-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc",
    "start": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "hono": "^4.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1",
    "@vitest/coverage-v8": "^3.1.1"
  }
}
